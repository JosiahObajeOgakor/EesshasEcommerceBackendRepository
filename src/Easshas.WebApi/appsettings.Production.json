{
  "ConnectionStrings": {
    "Postgres": "SET_VIA_ENV_VAR_ConnectionStrings__Postgres"
  },
  "Jwt": {
    "Key": "SET_VIA_ENV_VAR_Jwt__Key",
    "Issuer": "https://eeshasgloss.com",
    "Audience": "https://eeshasgloss.com",
    "ExpiryMinutes": 60,
    "CookieName": "access_token"
  },
  "Cors": {
    "Origins": [
      "https://eeshasgloss.com"
    ]
  },
  "Paystack": {
    "SecretKey": "SET_VIA_ENV_VAR_Paystack__SecretKey",
    "PublicKey": "SET_VIA_ENV_VAR_Paystack__PublicKey"
  },
  "Paystack:Subscriptions": {
    "SecretKey": "SET_VIA_ENV_VAR_Paystack__Subscriptions__SecretKey"
  },
  "Email": {
    "From": "no-reply@your-domain.com",
    "Admin": "admin@your-domain.com",
    "SesSecretName": "prod/SES"
  },
  "WhatsApp": {
    "Enabled": true,
    "RequireSubscription": true,
    "AdminPhone": "+2348000000000",
    "Provider": "Meta",
    "AccessToken": "SET_VIA_ENV_VAR_WhatsApp__AccessToken",
    "PhoneNumberId": "SET_VIA_ENV_VAR_WhatsApp__PhoneNumberId"
  },
  "AWS": {
    "Region": "us-east-2",
    "Bucket": "anythingais3bucket",
    "AccessKey": "SET_VIA_ENV_VAR_AWS__AccessKey",
    "SecretKey": "SET_VIA_ENV_VAR_AWS__SecretKey"
  }
