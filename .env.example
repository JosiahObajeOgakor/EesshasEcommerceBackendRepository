# Environment variable mappings for appsettings.json
# Use '__' to separate sections (e.g. Jwt__Key maps to Jwt:Key)
# Copy this file to .env and fill in the real values before running.

# --- PostgreSQL (used by docker-compose to initialise the database container) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=easshas

# Connection strings
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=easshas;Username=postgres;Password=CHANGE_ME_STRONG_DB_PASSWORD

# JWT
Jwt__Key=CHANGE_ME_AT_LEAST_32_CHAR_RANDOM_SECRET
Jwt__Issuer=https://eeshasgloss.com
Jwt__Audience=https://eeshasgloss.com
Jwt__ExpiryMinutes=60
Jwt__CookieName=access_token

# CORS (comma separated or multiple entries supported by deployment)
Cors__Origins__0=https://localhost:5173
Cors__Origins__1=https://localhost:3000
Cors__Origins__2=https://eeshasgloss.com
Cors__Origins__3=http://localhost:5272

# Paystack
Paystack__SecretKey=sk_test_REPLACE_WITH_YOUR_PAYSTACK_SECRET_KEY
Paystack__Subscriptions__SecretKey=sk_test_REPLACE_WITH_YOUR_PAYSTACK_SUBSCRIPTION_SECRET_KEY

# Email / SMTP
Email__Provider=Zoho
Email__From=support@Springuptechafrica.com
Email__Admin=support@Springuptechafrica.com
Email__Smtp__Host=smtp.zoho.com
Email__Smtp__Port=465
Email__Smtp__Username=support@Springuptechafrica.com
Email__Smtp__Password=CHANGE_ME_SMTP_PASSWORD
Email__Smtp__UseStartTls=true

# Contacts basic auth
Contacts__Auth__Username=contacts-user
Contacts__Auth__Password=CHANGE_ME_CONTACTS_PASS

# WhatsApp
WhatsApp__Enabled=false
WhatsApp__RequireSubscription=true
WhatsApp__AdminPhone=+2348000000000
WhatsApp__Provider=Meta
WhatsApp__AccessToken=CHANGE_ME_WHATSAPP_ACCESS_TOKEN
WhatsApp__PhoneNumberId=CHANGE_ME_WHATSAPP_PHONE_NUMBER_ID

# Admin seed user (avoid using in production; use secrets manager instead)
Admin__Username=
Admin__Password=
Admin__Email=admin@example.com

# AWS creds (rotate and store securely)
AWS__Region=us-east-2
AWS__Bucket=anythingais3bucket
AWS__AccessKey=CHANGE_ME_AWS_ACCESS_KEY_ID
AWS__SecretKey=CHANGE_ME_AWS_SECRET_ACCESS_KEY

# Payment URLs
Payment__ReturnUrlSuccess=http://localhost:3000/payment/success
Payment__ReturnUrlFailure=http://localhost:3000/payment/failed

# App specific
App__AI__Provider=OpenAI
App__AI__Model=gpt-4.1
App__AI__ApiKey=CHANGE_ME_OPENAI_API_KEY
App__Reconciliation__Enabled=false
App__Reconciliation__IntervalSeconds=300
App__Reconciliation__MinAgeMinutes=10
App__SeedOnStartup=false
App__Inventory__LowStockThreshold=5

# Rate limiting (anonymous)
App__RateLimiting__Anonymous__PermitLimit=60
App__RateLimiting__Anonymous__WindowSeconds=60
