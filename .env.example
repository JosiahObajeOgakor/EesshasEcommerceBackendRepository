# Environment variable mappings for appsettings.json
# Use '__' to separate sections (e.g. Jwt__Key maps to Jwt:Key)

# ── Docker / Postgres container ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=easshas

# Connection string used by the API container (host=db resolves to the compose service)
# Keep Username and Database in sync with POSTGRES_USER and POSTGRES_DB above
CONNECTIONSTRINGS_POSTGRES=Host=db;Port=5432;Database=easshas;Username=postgres;Password=CHANGE_ME_STRONG_DB_PASSWORD

# ── Runtime environment ────────────────────────────────────────────────────────
# Set to Production for live deployments
ASPNETCORE_ENVIRONMENT=Production

# ── JWT ────────────────────────────────────────────────────────────────────────
Jwt__Key=CHANGE_ME_256BIT_RANDOM_SECRET_KEY
Jwt__Issuer=https://eeshasgloss.com
Jwt__Audience=https://eeshasgloss.com
Jwt__ExpiryMinutes=60
Jwt__CookieName=access_token

# ── CORS (comma separated or multiple entries supported by deployment) ─────────
Cors__Origins__0=https://eeshasgloss.com

# ── Paystack ───────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_CHANGE_ME
Paystack__SecretKey=sk_live_CHANGE_ME

# ── Email / SMTP ───────────────────────────────────────────────────────────────
EMAIL_FROM=support@Springuptechafrica.com
EMAIL_ADMIN=support@Springuptechafrica.com
EMAIL_SMTP_HOST=smtp.zoho.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USERNAME=support@Springuptechafrica.com
EMAIL_SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_SMTP_USE_STARTTLS=true

# ── Contacts basic auth ────────────────────────────────────────────────────────
CONTACTS_AUTH_USERNAME=contacts-user
CONTACTS_AUTH_PASSWORD=CHANGE_ME_CONTACTS_PASS

# ── WhatsApp ───────────────────────────────────────────────────────────────────
WhatsApp__Enabled=false
WhatsApp__RequireSubscription=true
WhatsApp__AdminPhone=+2348000000000
WhatsApp__Provider=Meta
WhatsApp__AccessToken=CHANGE_ME_WHATSAPP_ACCESS_TOKEN
WhatsApp__PhoneNumberId=CHANGE_ME_WHATSAPP_PHONE_NUMBER_ID

# ── Admin seed user (avoid using in production; use secrets manager instead) ───
Admin__Username=
Admin__Password=
Admin__Email=admin@example.com

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-2
AWS__Region=us-east-2
AWS__Bucket=anythingais3bucket
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY

# ── Payment URLs ───────────────────────────────────────────────────────────────
Payment__ReturnUrlSuccess=https://eeshasgloss.com/payment/success
Payment__ReturnUrlFailure=https://eeshasgloss.com/payment/failed

# ── App specific ───────────────────────────────────────────────────────────────
App__AI__Provider=OpenAI
App__AI__Model=gpt-4.1
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
App__Reconciliation__Enabled=false
App__Reconciliation__IntervalSeconds=300
App__Reconciliation__MinAgeMinutes=10
App__SeedOnStartup=false
App__Inventory__LowStockThreshold=5

# ── CORS origin for docker-compose ────────────────────────────────────────────
CORS_ORIGIN_0=https://eeshasgloss.com

# ── Rate limiting (anonymous) ──────────────────────────────────────────────────
App__RateLimiting__Anonymous__PermitLimit=60
App__RateLimiting__Anonymous__WindowSeconds=60
